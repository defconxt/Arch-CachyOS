-- DCS World VR settings block from options.lua
-- Location: <prefix>/drive_c/users/<user>/Saved Games/DCS/Config/options.lua
--
-- These are tested values for RTX 5090 + Quest 3 via WiVRn (AV1 nvenc).
-- Paste or merge into your options.lua under the ["VR"] key.
--
-- NOTE: pixel_density is 1.3 here. If you see double-scaling artifacts,
-- drop to 1.0 — WiVRn already renders at Quest 3 native res (2064x2208).

["VR"] = {
    ["bloom"] = true,
    ["box_mouse_cursor"] = true,
    ["custom_IPD"] = 63.5,
    ["custom_IPD_enable"] = false,
    ["enable"] = true,
    ["enableHMDMask"] = true,
    ["handOffsetX"] = 0,
    ["handOffsetY"] = 0,
    ["handOffsetZ"] = 0,
    ["hand_controllers"] = false,
    ["hand_controllers_debug_draw"] = false,
    ["hand_controllers_joint_throttle"] = false,
    ["hand_controllers_type"] = 0,
    ["hand_controllers_use_stick"] = true,
    ["hand_controllers_use_throttle"] = true,
    ["interaction_with_grip_only"] = false,
    ["mirror_crop"] = false,
    ["mirror_source"] = 0,
    ["mirror_use_DCS_resolution"] = false,
    ["msaaMaskSize"] = 0.6,
    ["openxr_eyeGaze"] = false,
    ["openxr_quadView"] = false,
    ["pixel_density"] = 1.3,
    ["pointer_use_type"] = 0,
    ["prefer_built_in_audio"] = true,
    ["use_mouse"] = true,
},
